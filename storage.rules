rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Check if the request is from an authenticated admin user
    function isAdmin() {
      return request.auth != null;
    }

    // Public portraits (readable by anyone, upload restricted to admin, max 5MB, image only)
    match /portraits/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && request.resource.size < 5 * 1024 * 1024 && request.resource.contentType.matches('image/.*');
    }

    // Project/Blog images (readable by anyone, upload restricted to admin, max 10MB, image only)
    match /media/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && request.resource.size < 10 * 1024 * 1024 && request.resource.contentType.matches('image/.*');
    }

    // PDF files/Documents (readable by anyone, upload restricted to admin, max 20MB)
    match /documents/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && request.resource.size < 20 * 1024 * 1024 && request.resource.contentType == 'application/pdf';
    }
  }
}
