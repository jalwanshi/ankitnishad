rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Check if the request is from an authenticated admin user
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }

    // Public collections (read-only for public, write for admin)
    match /profile/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /career/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /skills/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /blogs/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /services/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /projects/{document} {
      allow read: if resource.data.published == true || isAdmin();
      allow write: if isAdmin();
    }
    
    match /blogPosts/{document} {
      allow read: if resource.data.status == "published" || isAdmin();
      allow write: if isAdmin();
    }
    
    // Enquiry & CRM Data
    match /enquiries/{document} {
      allow create: if true; // anyone can submit a contact inquiry
      allow read, update, delete: if isAdmin(); // only admin can access/manage
    }

    match /followUps/{document} {
      allow read, write: if isAdmin(); // only admin has access
    }
    
    match /adminUsers/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if isAdmin();
    }
  }
}
